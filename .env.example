# ── API Key de Google AI Studio (Gemini) ────────────────────────────────────
# Obtener en: https://aistudio.google.com → Get API key → Create API key
GEMINI_API_KEY=AIza...ponla-aqui...

# ── SharePoint sincronizado por OneDrive ─────────────────────────────────────
# Windows: C:\Users\tu_usuario\OneDrive - Empresa\Documentos
# Mac:     /Users/tu_usuario/Library/CloudStorage/OneDrive-Empresa/Documentos
SHAREPOINT_DIR=

# ── Ruta directa a la carpeta Comercial de Renta ─────────────────────────────
# Carpeta que contiene subcarpetas por año (2025/, 2026/, etc.)
# Windows (SharePoint): C:\Users\raimundo.opazo\OneDrive - Empresa\...\Control de Gestión Históricos\Comercial
# Windows (R: drive):   R:\Planillas\Rentas\Control de Gestión Rentas Inmobiliarias\Control de Gestión Históricos\Comercial
# Mac:                  /Users/tu_usuario/Library/CloudStorage/OneDrive-Empresa/...\Comercial
RENTA_COMERCIAL_DIR=

# ── Servidor local / unidad de red (solo Windows, opcional) ──────────────────
# Solo necesario si usas el servidor R: en lugar de SharePoint
# LOCAL_FILES_DIR=R:\Planillas

# ── Directorio de trabajo temporal (default: ./work) ─────────────────────────
# WORK_DIR=C:\Users\raimundo.opazo\automation_agent\work
